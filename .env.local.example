# ──────────────────────────────────────────────────────────────────
# realdekant — .env.local template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────────

# ─── Firebase (client-side — safe to expose with NEXT_PUBLIC_) ────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ─── ImgBB (client-side — upload API key) ────────────────────────
# Get your API key from: https://api.imgbb.com/
# Note: NEXT_PUBLIC_ prefix means this is exposed in the browser.
# ImgBB public upload keys are designed to be client-side safe.
NEXT_PUBLIC_IMGBB_API_KEY=your_imgbb_api_key

# ─── App config ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=realdekant

# ─── Firebase Admin SDK (server-side — NEVER expose) ──────────────
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Paste the entire JSON on one line:
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ─── Admin Setup (one-time use — can remove after setting claim) ──
ADMIN_SETUP_SECRET=your_random_secret_here
